{
  "name": "name",
  "browser": {
    "typeorm": false
  },
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npm run migration:run && next start",
    "lint": "next lint",
    "typeorm": "ts-node -P ./app/db/tsconfig.json ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm migration:create ./app/db/migrations/SetupClusterIndexes",
    "migration:generate": "npm run typeorm migration:generate ./app/db/migrations/CreateTables -- -d ./app/db/data-source.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./app/db/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d ./app/db/data-source.ts",
    "format": "prettier \"**/*.{ts,cjs,js,jsx}\" --check --ignore-unknown",
    "format:write": "prettier \"**/*.{ts,cjs,js,jsx}\" --write --ignore-unknown",
    "lint-staged": "lint-staged",
    "pre-commit": "npm run format:write && npm run lint",
    "compile": "tsc"
  },
  "dependencies": {
    "@auth/typeorm-adapter": "^2.7.4",
    "@faker-js/faker": "^9.3.0",
    "@heroicons/react": "^2.2.0",
    "@mantine/core": "^7.14.3",
    "@next/env": "^15.1.2",
    "@tailwindcss/forms": "^0.5.9",
    "argon2": "^0.41.1",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^2.19.0",
    "junit2json": "^3.1.13",
    "next": "15.0.3",
    "next-auth": "^5.0.0-beta.25",
    "pg": "^8.13.1",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.20",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "tsx": "^4.19.2"
  }
}
